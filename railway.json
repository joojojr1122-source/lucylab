# Railway (https://railway.app) — deploys the server (long-running Node).
# The web frontend is built and served by the server in production,
# so one service handles everything. Set these in the Railway dashboard:
#   PORT (auto), REDIS_URL, FAL_KEY, LIVEKIT_*, STRIPE_*, PUBLIC_SERVER_URL
{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": ["packages/server/**", "packages/shared/**", "package.json"]
  },
  "deploy": {
    "healthcheckPath": "/api/config",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1
  }
}
