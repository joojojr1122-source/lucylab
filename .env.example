# Lucy Call - environment variables

# fal.ai API key (server-side only, never exposed to the browser).
# Get it from https://fal.ai/dashboard/keys
FAL_KEY=

# LiveKit credentials (server-side only). Create an project at https://livekit.io
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# Public URL the web/desktop client uses to reach this server.
# In dev this is usually http://localhost:8787
PUBLIC_SERVER_URL=http://localhost:8787

# Server port
PORT=8787

# fal Lucy 2.5 realtime endpoint (fal)
FAL_LUCY_ENDPOINT=decart/lucy-2-5/realtime

# Users + identity (accounts required to use the app)
# Postgres for durable accounts. Leave unset to use in-memory (dev only).
# DATABASE_URL=postgres://lucy:lucy@localhost:5432/lucy

# Credit metering
CREDIT_RATE_PER_SECOND=0.05   # $ per streamed second
FREE_CREDITS=10               # free minutes granted per new account
# REDIS_URL=redis://localhost:6379   # leave unset to use in-memory store

# Stripe (real top-ups + Stripe Identity KYC). Leave unset to disable.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=        # verifies payments + identity sessions
# VITE_STRIPE_PUBLISHABLE_KEY=   # client-side, set in shell / CI for the web build
# Stripe Identity must be enabled on your Stripe account for verification.

# Google OAuth login (optional). Leave unset to disable.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# PUBLIC_SERVER_URL must match the OAuth redirect allow-list (.../api/auth/google/callback).

# Email (verification emails). Leave SMTP_* unset to log links to console (dev).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Lucy Call <noreply@yourdomain.com>"
# nodemailer is used for delivery when SMTP_HOST is set.
