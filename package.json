{
  "name": "lucy-call",
  "version": "0.1.0",
  "private": true,
  "description": "Commercial real-time video call product with Lucy 2.5 avatar transformation and background changing.",
  "workspaces": [
    "packages/shared",
    "packages/web",
    "packages/desktop",
    "packages/server"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace packages/server",
    "dev:web": "npm run dev --workspace packages/web",
    "dev:desktop": "npm run dev --workspace packages/desktop",
    "build:web": "npm run build --workspace packages/web",
    "build:desktop": "npm run build --workspace packages/desktop"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
